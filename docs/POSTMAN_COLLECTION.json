  "item": [
    {
      "name": "Login Worker",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{backend}}/auth/login",
          "host": ["{{backend}}"],
          "path": ["auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"asha@blinkshield.demo\",\n  \"password\": \"Pass@123\"\n}"
        }
      }
    },
    {
      "name": "Calculate Premium",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{backend}}/premium/calculate",
          "host": ["{{backend}}"],
          "path": ["premium", "calculate"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"workerId\": \"{{workerId}}\"\n}"
        }
      }
    },
    {
      "name": "Simulate Heavy Rainfall",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{backend}}/disruptions/simulate",
          "host": ["{{backend}}"],
          "path": ["disruptions", "simulate"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"heavy_rainfall\",\n  \"zone\": \"Koramangala-5th-Block\"\n}"
        }
      }
    },
